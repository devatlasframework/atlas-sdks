#!/bin/sh
# ATLAS pre-commit hook: secret scan now; format/lint/quick tests as toolchains land.
# Enable once per clone:  git config core.hooksPath .githooks

# Compare against HEAD, or the empty tree on the very first commit.
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  against=HEAD
else
  against=$(git hash-object -t tree /dev/null)
fi
staged=$(git diff --cached --name-only --diff-filter=ACM "$against")
[ -z "$staged" ] && exit 0

fail=0

# --- 1. Secret scan (always on) ---------------------------------------------
pattern='-----BEGIN [A-Z ]*PRIVATE KEY-----|AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9_-]{20,}|gh[pousr]_[A-Za-z0-9]{20,}|postgres(ql)?://[^/ :]+:[^@ ]+@'
for f in $staged; do
  case "$f" in
    *.png|*.jpg|*.jpeg|*.gif|*.ico|*.pdf|*.zip|*.jar|*.woff|*.woff2|*.svg) continue ;;
    .githooks/*|.claude/hooks/*) continue ;;
  esac
  if git show ":$f" | grep -nE -e "$pattern" >/dev/null 2>&1; then
    echo "pre-commit: possible secret in $f - remove it before committing:" >&2
    git show ":$f" | grep -nE -e "$pattern" | head -5 >&2
    fail=1
  fi
done

# --- 2. Fast format/lint checks on staged files ------------------------------
# Kept fast on purpose: prettier + ruff only. Full eslint, tests, and the Maven
# build run in CI (and via the /pre-commit-check command).

# Prettier over staged TS/JS/JSON/YAML/MD (skips api + ingestion trees).
pretty_files=$(echo "$staged" | grep -E '\.(ts|tsx|mjs|js|jsx|json|ya?ml|md|css)$' | grep -vE '^apps/(api|ingestion)/' || true)
if [ -n "$pretty_files" ] && [ -d node_modules ] && command -v pnpm >/dev/null 2>&1; then
  if ! echo "$pretty_files" | tr '\n' '\0' | xargs -0 pnpm exec prettier --check --ignore-unknown >/dev/null 2>&1; then
    echo "pre-commit: prettier check failed - run 'pnpm format' and restage:" >&2
    echo "$pretty_files" | tr '\n' '\0' | xargs -0 pnpm exec prettier --check --ignore-unknown 2>&1 | grep -v '^Checking' | head -10 >&2
    fail=1
  fi
fi

# Ruff (lint + format) when ingestion Python files are staged.
py_staged=$(echo "$staged" | grep -E '^apps/ingestion/.*\.py$' || true)
if [ -n "$py_staged" ] && command -v uv >/dev/null 2>&1; then
  if ! (cd apps/ingestion && uv run ruff check . && uv run ruff format --check .) >/dev/null 2>&1; then
    echo "pre-commit: ruff failed in apps/ingestion:" >&2
    (cd apps/ingestion && { uv run ruff check . 2>&1; uv run ruff format --check . 2>&1; } | head -8 >&2)
    fail=1
  fi
fi

if [ $fail -ne 0 ]; then
  echo "pre-commit: blocked. Fix the findings above (never use --no-verify)." >&2
  exit 1
fi
exit 0
